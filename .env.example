# ==============================================================================
# 🛡️ INFRAMEET - ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ==============================================================================

# Core Application Settings
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://inframeet.vercel.app

# Supabase Configurations (Database & Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL Connection String
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Xendit Payment Gateway (Sandbox/Production)
XENDIT_SECRET_KEY=xnd_development_...
XENDIT_PUBLIC_KEY=xnd_public_development_...
XENDIT_WEBHOOK_TOKEN=your-webhook-token

# SendGrid Transactional Email Service
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=inframeet@emailforums.biz
SENDGRID_SUPPORT_EMAIL=inframeet@emailforums.biz

# Advanced SMTP Mail Configuration Credentials
SMTP_HOST=smtp.emailforums.biz
SMTP_PORT=465
SMTP_USER=inframeet@emailforums.biz
SMTP_PASSWORD=your-smtp-password
SMTP_SECURE=true

# Incoming POP3/IMAP Configuration Settings
IMAP_HOST=imap.emailforums.biz
IMAP_PORT=993
POP3_HOST=pop3.emailforums.biz
POP3_PORT=995

# AI NLP Models API Keys (Groq & Gemini Google)
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIzaSy...

# UptimeRobot Main API Key (Keep-Alive Database Cron)
UPTIMEROBOT_API_KEY=u...

# System Cryptography (NextAuth Key)
NEXTAUTH_SECRET=your-random-cryptographic-key-here
