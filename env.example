# ============================================================================
# INFRAMEET — ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION (Required)
# ----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_PASSWORD=your-database-password

# Database Direct Connection (for migrations & workers)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ----------------------------------------------------------------------------
# AUTHENTICATION (Supabase Auth)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Auth (optional - for custom email templates)
SUPABASE_SMTP_HOST=smtp.gmail.com
SUPABASE_SMTP_PORT=587
SUPABASE_SMTP_USER=your-email@gmail.com
SUPABASE_SMTP_PASSWORD=your-app-password

# ----------------------------------------------------------------------------
# CLOUDFLARE TURNSTILE (Anti-Abuse - Required)
# ----------------------------------------------------------------------------
# Get from: https://dash.cloudflare.com/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ----------------------------------------------------------------------------
# FILE STORAGE (Choose ONE)
# ----------------------------------------------------------------------------
# Option A: Cloudflare R2 (Recommended for cost)
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=inframeet-storage
CLOUDFLARE_R2_PUBLIC_URL=https://storage.your-domain.com

# Option B: Cloudinary (Alternative)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=inframeet-uploads

# Option C: Supabase Storage (Free tier limited)
# Uses same Supabase credentials above
SUPABASE_STORAGE_BUCKET=inframeet-files

# ----------------------------------------------------------------------------
# AI / EMBEDDINGS (For Semantic Search - Optional)
# ----------------------------------------------------------------------------
# Option A: OpenAI
OPENAI_API_KEY=sk-...

# Option B: Hugging Face (Free)
HUGGINGFACE_API_KEY=hf_...

# Option C: Local Ollama (No API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Model Selection
EMBEDDING_PROVIDER=openai # openai | huggingface | ollama
EMBEDDING_MODEL=text-embedding-3-small # or all-MiniLM-L6-v2 for HF

# ----------------------------------------------------------------------------
# EXTERNAL INTEGRATIONS (Optional but Recommended)
# ----------------------------------------------------------------------------

# RSS Feed Ingestion
RSS_FEEDS_ENABLED=true

# OpenAlex API (Academic profiles)
OPENALEX_API_EMAIL=your-email@domain.com # polite pool access

# Google Safe Browsing API (Security)
GOOGLE_SAFE_BROWSING_API_KEY=your-api-key

# ----------------------------------------------------------------------------
# NOTIFICATIONS (Choose what you need)
# ----------------------------------------------------------------------------

# Email Service (Choose ONE)
# Option A: Resend (Recommended)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@your-domain.com

# Option B: SendGrid
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# Option C: Mailgun
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=mg.your-domain.com

# Telegram Bot (Admin notifications)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ADMIN_CHAT_ID=123456789

# WhatsApp Business API (Optional)
WHATSAPP_PHONE_NUMBER_ID=your-phone-id
WHATSAPP_ACCESS_TOKEN=your-access-token

# ----------------------------------------------------------------------------
# PAYMENT / ESCROW (Optional - Future Phase)
# ----------------------------------------------------------------------------
# Stripe
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Xendit (Indonesia-friendly)
XENDIT_PUBLIC_KEY=xnd_public_...
XENDIT_SECRET_KEY=xnd_...
XENDIT_WEBHOOK_SECRET=your-webhook-secret

# ----------------------------------------------------------------------------
# RATE LIMITING & SECURITY
# ----------------------------------------------------------------------------
# Redis (for distributed rate limiting - optional)
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=your-redis-token # if using Upstash

# Rate Limit Rules (requests per window)
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100

# Inquiry Rate Limit (per IP)
INQUIRY_RATE_LIMIT_MAX=5
INQUIRY_RATE_LIMIT_WINDOW_HOURS=24

# Widget Event Rate Limit
WIDGET_EVENT_RATE_LIMIT_MAX=1000
WIDGET_EVENT_RATE_LIMIT_WINDOW_HOURS=1

# ----------------------------------------------------------------------------
# TRUST SCORE ENGINE CONFIGURATION
# ----------------------------------------------------------------------------
TRUST_SCORE_DECAY_ENABLED=true
TRUST_SCORE_DECAY_RATE=0.02 # 2% monthly decay
TRUST_SCORE_RECALC_INTERVAL_HOURS=24

# Reputation Points
POINTS_PROOF_APPROVED=15
POINTS_VERIFIED_REVIEW=10
POINTS_ESCROW_RELEASED=20
POINTS_WIDGET_INSTALL=5
POINTS_CLAIM_VERIFIED=25
POINTS_SPAM_PENALTY=-30
POINTS_FRAUD_PENALTY=-50

# ----------------------------------------------------------------------------
# WORKER AUTOMATION (GitHub Actions)
# ----------------------------------------------------------------------------
# Worker API Secret (for authenticated cron calls)
WORKER_API_SECRET=your-random-secret-key-min-32-chars

# Worker Scheduling
WORKER_RSS_CRON=0 */6 * * * # Every 6 hours
WORKER_DECAY_CRON=0 2 * * * # Daily at 2 AM
WORKER_WIDGET_REWARDS_CRON=0 3 * * * # Daily at 3 AM
WORKER_CLEANUP_CRON=0 4 * * SUN # Weekly Sunday 4 AM

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
FEATURE_ESCROW_ENABLED=false
FEATURE_VERIFIED_REVIEWS_ENABLED=true
FEATURE_WIDGET_GROWTH_ENABLED=true
FEATURE_RSS_INGESTION_ENABLED=true
FEATURE_SEMANTIC_SEARCH_ENABLED=false
FEATURE_ACADEMIC_PROFILES_ENABLED=true
FEATURE_FIS_ENABLED=false # Founder Intelligence System

# ----------------------------------------------------------------------------
# MONITORING & LOGGING (Optional)
# ----------------------------------------------------------------------------
# Sentry (Error tracking)
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id

# PostHog (Product analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ----------------------------------------------------------------------------
# SEO & METADATA
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME=INFRAMEET
NEXT_PUBLIC_SITE_DESCRIPTION="Adaptive Trust Infrastructure & Omni-Storefront Directory"
NEXT_PUBLIC_SITE_DOMAIN=inframeet.com
NEXT_PUBLIC_OG_IMAGE=https://your-domain.com/og-image.png

# ----------------------------------------------------------------------------
# DEVELOPMENT & DEBUG
# ----------------------------------------------------------------------------
NODE_ENV=development # production | development | test
DEBUG_MODE=false
LOG_LEVEL=info # error | warn | info | debug

# Skip captcha in dev (BE CAREFUL!)
DEV_SKIP_CAPTCHA=false

# ----------------------------------------------------------------------------
# ADMIN SETTINGS
# ----------------------------------------------------------------------------
ADMIN_EMAIL=admin@your-domain.com
ADMIN_INITIAL_PASSWORD=change-this-immediately

# Auto-approve first user as admin
FIRST_USER_IS_ADMIN=true

# ----------------------------------------------------------------------------
# LEGAL & COMPLIANCE
# ----------------------------------------------------------------------------
TERMS_OF_SERVICE_URL=https://your-domain.com/terms
PRIVACY_POLICY_URL=https://your-domain.com/privacy
CONTACT_EMAIL=contact@your-domain.com

# GDPR Compliance
GDPR_MODE=false # Enable for EU users

# ----------------------------------------------------------------------------
# BACKUP & RECOVERY (Optional)
# ----------------------------------------------------------------------------
BACKUP_ENABLED=false
BACKUP_S3_BUCKET=inframeet-backups
BACKUP_S3_REGION=us-east-1
BACKUP_RETENTION_DAYS=30

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
